{
  "name": "purrbit",
  "description": "Mini Tamagotchi-style Cat Game",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "pages/home.html"
  },
  "web_accessible_resources": [
    {
      "resources": [ "../assets/bgm/bgm-marimba.wav", "../assets/bgm/bgm-piano.wav" ],
	  "matches": [ "<all_urls>" ]
	}
	],
  "permissions": ["storage"]
}
